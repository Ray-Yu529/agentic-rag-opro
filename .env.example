# 複製成 .env 並填入你的金鑰 (build.nvidia.com 註冊後產生，nvapi- 開頭)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (選填) 覆寫模型 id — 端點 404/不穩時換模型，或換私有 OpenAI 相容端點用。
# 注意: 換 GEN/EMBED/JUDGE 模型會讓評估 cache 自動失效 (快取鍵含模型指紋)。
# JUDGE_MODEL 建議選與 GEN_MODEL 不同家族的模型 (避免判官自我偏袒)。
# GEN_MODEL=meta/llama-3.1-8b-instruct
# EMBED_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
# JUDGE_MODEL=mistralai/mixtral-8x7b-instruct-v0.1
# META_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# QA_GEN_MODEL=nvidia/llama-3.1-nemotron-70b-instruct  # 自訂文件的 QA 生成 (預設同 META_MODEL)
# VLM_MODEL=meta/llama-3.2-11b-vision-instruct  # 掃描 PDF 頁的轉錄 (只有無文字層的頁面用)
# RERANK_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2  # 專用 reranker；設 dense 退回舊行為
# RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/llama-3_2-nv-rerankqa-1b-v2/reranking
